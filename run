#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

usage() {
    echo "Usage: $0 <command>"
    echo ""
    echo "Commands:"
    echo "  agent    Run the monitoring agent"
    echo "  serve    Serve the UI on port 8090"
    echo "  test     Run Python tests"
    echo "  check    Run all tests"
    exit 1
}

cmd_agent() {
    cd "$SCRIPT_DIR"
    exec python3 -u agent/agent.py "$@"
}

cmd_serve() {
    cd "$SCRIPT_DIR"
    exec python3 ui/server.py 8090
}

cmd_test() {
    echo "==> Running tests..."
    cd "$SCRIPT_DIR"
    python3 -m pytest lib/test_monitor.py -v
    echo "==> Tests passed."
}

cmd_check() {
    cmd_test
}

case "${1:-}" in
    agent)  shift; cmd_agent "$@" ;;
    serve)  shift; cmd_serve "$@" ;;
    test)   shift; cmd_test "$@" ;;
    check)  shift; cmd_check "$@" ;;
    *)      usage ;;
esac
